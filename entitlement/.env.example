# Entitlement service — copy to `.env` and fill from secret store.

ENTITLEMENT_POSTGRES_USER=entitlement
ENTITLEMENT_POSTGRES_PASSWORD=change-me-from-secret-store
ENTITLEMENT_POSTGRES_DB=entitlement
ENTITLEMENT_TAG=dev
BUILD_DIGEST=dev

# Optional shared secret for relay → entitlement introspection (Bearer).
ENTITLEMENT_INTERNAL_TOKEN=

# Trial and grace durations (Go duration syntax).
TRIAL_DURATION=336h
GRACE_DURATION=168h
