# Compartarenta VPS stack — merged environment template (relay + entitlement).
#
# Copy to /srv/compartarenta-relay/env/.env on the VPS, fill secrets from
# your secret store, chmod 0600. Never commit a populated file.
#
# See docs/stack-deployment.md for the full runbook.

# =============================================================================
# Relay PostgreSQL (existing deployment — keep your current values)
# =============================================================================
POSTGRES_USER=relay
POSTGRES_PASSWORD=change-me-from-secret-store
POSTGRES_DB=relay

# =============================================================================
# Entitlement PostgreSQL (separate database — new)
# =============================================================================
ENTITLEMENT_POSTGRES_USER=entitlement
ENTITLEMENT_POSTGRES_PASSWORD=change-me-from-secret-store
ENTITLEMENT_POSTGRES_DB=entitlement

# =============================================================================
# Image tags and build digests (surfaced via /healthz)
# =============================================================================
RELAY_TAG=dev
ENTITLEMENT_TAG=dev
BUILD_DIGEST=dev
# Optional separate digest for entitlement image; defaults to BUILD_DIGEST.
# ENTITLEMENT_BUILD_DIGEST=dev

# =============================================================================
# Relay protocol (see relay/.env.example for detail)
# =============================================================================
ENVELOPE_MAX_BYTES=262144
CORS_ALLOWED_ORIGINS=

WAKE_PUSH_DISPATCH_ENABLED=false
# FCM_SERVICE_ACCOUNT_JSON_PATH=
# APNS_AUTH_KEY_PATH=
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=
# APNS_ENVIRONMENT=production
ROUTING_PUSH_TOKEN_TTL_SECONDS=1209600
STATS_LISTEN_ADDR=127.0.0.1:9091
REMINDER_CRON_ENABLED=false

# =============================================================================
# Entitlement service + relay gating
# =============================================================================
# Set false only while rolling out entitlement before clients send
# entitlement_gate on gated housing envelopes (kinds 5–9).
ENTITLEMENT_ENABLED=true

# Docker DNS name on stack-net (do not change unless you rename the service).
ENTITLEMENT_INTROSPECT_URL=http://entitlement:8080

# Strong random string shared by relay and entitlement containers.
# Generate once, store in secret manager, paste the same value here.
ENTITLEMENT_INTERNAL_TOKEN=change-me-from-secret-store

TRIAL_DURATION=336h
GRACE_DURATION=168h

# =============================================================================
# Operator cron (host-side, not read by containers)
# =============================================================================
# Daily stats: use daily-stats-append-via-docker.sh in crontab (see
# docs/stack-deployment.md). STATS_FILE_PATH is read by that script.
STATS_FILE_PATH=/srv/compartarenta-stats/daily.jsonl
