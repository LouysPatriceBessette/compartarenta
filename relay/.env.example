# Compartarenta relay — reference environment file.
#
# Copy this file to `.env` next to compose.yml and fill in real values
# from your secret store. **Never commit a populated .env to the
# repository.** `.gitignore` lists `.env` to keep operators honest.
#
# Per `relay-security-baseline` /
# "Secrets are managed by an explicit secret store", these values come
# from an explicit secret-management mechanism at deploy time
# (HashiCorp Vault, Doppler, age-encrypted file, sealed-secrets, env
# injection from the CI runner — operator's choice). The relay never
# embeds them in source or image layers.

# --- PostgreSQL credentials (used by the postgres container + DSN) ---
POSTGRES_USER=relay
POSTGRES_PASSWORD=change-me-from-secret-store
POSTGRES_DB=relay

# --- Container image tag pinned to the deployed digest ---
RELAY_TAG=dev
BUILD_DIGEST=dev

# --- Envelope size cap ---
#
# Maximum ciphertext size accepted for a single POST /v1/envelopes request.
# 262144 = 256 KiB. This keeps a single compressed proof image practical
# while remaining far below the binary's 1 MiB ceiling.
ENVELOPE_MAX_BYTES=262144

# --- CORS allow-list for browser callers (optional) ---
# Comma-separated list of origins (scheme + host + optional port) that
# may issue cross-origin XHR/fetch requests against /v1/* . Used by the
# Flutter Web build (and any other in-browser tooling).
#
# Examples:
#   CORS_ALLOWED_ORIGINS=http://localhost:5001
#   CORS_ALLOWED_ORIGINS=http://localhost:5001,http://localhost:5002
#   CORS_ALLOWED_ORIGINS=*    # development only — browsers reject `*`
#                              # for requests that send credentials
#
# Leave unset/empty in production unless a browser-served origin is part
# of the supported deployment topology. The default (empty) blocks
# browser callers at the same-origin boundary.
CORS_ALLOWED_ORIGINS=

# --- Closed-app push delivery (WhatsApp-like wake) ---

# Master switch for best-effort FCM/APNs wake dispatch after envelope
# persistence. Default false: routing push tokens are still accepted and
# stored, but no third-party push call is made. Flip to true once the
# operator credentials below are provisioned.
WAKE_PUSH_DISPATCH_ENABLED=false

# Firebase service account JSON (FCM HTTP v1) — required when
# WAKE_PUSH_DISPATCH_ENABLED=true and you target Android.
# FCM_SERVICE_ACCOUNT_JSON_PATH=/path/inside/container/fcm-service-account.json

# APNs auth bundle — required when WAKE_PUSH_DISPATCH_ENABLED=true and
# you target iOS. All four keys must be set together.
# APNS_AUTH_KEY_PATH=/path/inside/container/AuthKey_XXXX.p8
# APNS_KEY_ID=ABCDE12345
# APNS_TEAM_ID=ZYXWV98765
# APNS_BUNDLE_ID=org.example.compartarenta
# APNS_ENVIRONMENT=production           # or "sandbox" for TestFlight
# APNS_GENERIC_ALERT_BODY=              # optional non-personalized iOS alert body

# Server-side lifetime applied on each routing-push token registration
# refresh. Bounds: 86400 (1 day) ≤ value ≤ 7776000 (90 days). Default
# 1209600 (14 days). The general sweeper (SWEEPER_INTERVAL, default 1m)
# also purges expired rows; no separate purge cadence variable is exposed
# at the binary level — the spec's earlier
# ROUTING_PUSH_TOKEN_PURGE_INTERVAL_SECONDS was replaced by reuse of the
# sweeper at implementation time.
ROUTING_PUSH_TOKEN_TTL_SECONDS=1209600

# --- Daily stats listener (loopback only) ---

# Bind address of the second HTTP listener exposing
# GET /internal/stats/daily. Default 127.0.0.1:9091. Use "-" to disable
# the listener entirely. Only loopback callers receive data; other remote
# addresses get HTTP 404.
STATS_LISTEN_ADDR=127.0.0.1:9091

# --- Entitlement gating (housing envelope kinds 5–9) ---

# When true, gated housing envelopes require entitlement_gate metadata and
# a successful introspection call to the entitlement service.
ENTITLEMENT_ENABLED=false

# Base URL of the entitlement service (private network), e.g.
# http://entitlement:8080 when both services share a Docker network.
# ENTITLEMENT_INTROSPECT_URL=http://127.0.0.1:8081

# Optional Bearer token shared with the entitlement service.
# ENTITLEMENT_INTERNAL_TOKEN=

# Path of the JSONL file appended to by scripts/daily-stats-append.sh.
# Read by the cron script, NOT by the relay binary. Default
# /srv/compartarenta-stats/daily.jsonl. The directory must exist and be
# owned by the user that runs the cron (typically `compartarenta-relay`).
STATS_FILE_PATH=/srv/compartarenta-stats/daily.jsonl
