# Compartarenta relay — reference environment file.
#
# Copy this file to `.env` next to compose.yml and fill in real values
# from your secret store. **Never commit a populated .env to the
# repository.** `.gitignore` lists `.env` to keep operators honest.
#
# Per `relay-security-baseline` /
# "Secrets are managed by an explicit secret store", these values come
# from an explicit secret-management mechanism at deploy time
# (HashiCorp Vault, Doppler, age-encrypted file, sealed-secrets, env
# injection from the CI runner — operator's choice). The relay never
# embeds them in source or image layers.

# --- PostgreSQL credentials (used by the postgres container + DSN) ---
POSTGRES_USER=relay
POSTGRES_PASSWORD=change-me-from-secret-store
POSTGRES_DB=relay

# --- Container image tag pinned to the deployed digest ---
RELAY_TAG=dev
BUILD_DIGEST=dev

# --- CORS allow-list for browser callers (optional) ---
# Comma-separated list of origins (scheme + host + optional port) that
# may issue cross-origin XHR/fetch requests against /v1/* . Used by the
# Flutter Web build (and any other in-browser tooling).
#
# Examples:
#   CORS_ALLOWED_ORIGINS=http://localhost:5001
#   CORS_ALLOWED_ORIGINS=http://localhost:5001,http://localhost:5002
#   CORS_ALLOWED_ORIGINS=*    # development only — browsers reject `*`
#                              # for requests that send credentials
#
# Leave unset/empty in production unless a browser-served origin is part
# of the supported deployment topology. The default (empty) blocks
# browser callers at the same-origin boundary.
CORS_ALLOWED_ORIGINS=
